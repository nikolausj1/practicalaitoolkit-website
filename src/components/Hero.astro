---
// Hero section: the talk title + subhead + scroll cue.
---
<div class="hero" id="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">A talk by Justin Nikolaus</p>
    <h1>Practical AI</h1>
    <h2>Use AI confidently. Today.</h2>
    <div class="subtitle">
      A plain-language guide to what AI is, when to use it, and how to get great results — built around the 2026 talk.
    </div>
    <div class="hero-buttons">
      <a href="#what-is-ai" class="cta-button">Start at the Beginning</a>
      <a href="#prompting-tips" class="cta-button cta-button--ghost">Jump to Prompting Tips</a>
    </div>
  </div>
</div>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 40px;
    position: relative;
    background: linear-gradient(135deg, #001f3f 0%, #002a55 60%, #001428 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(0, 102, 204, 0.25) 0%, transparent 45%),
      radial-gradient(circle at 80% 70%, rgba(0, 102, 204, 0.18) 0%, transparent 45%);
    z-index: 0;
  }

  .hero-content {
    max-width: 900px;
    text-align: left;
    background: rgba(0, 31, 63, 0.78);
    backdrop-filter: blur(10px);
    border-left: 5px solid var(--brand-blue);
    padding: 80px;
    position: relative;
    z-index: 1;
    animation: fadeInUp 1s ease;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .hero h1 {
    font-size: 88px;
    font-weight: 700;
    margin: 0 0 18px 0;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero h2 {
    font-size: 38px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 30px 0;
  }

  .hero .subtitle {
    font-size: 22px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.78);
    padding-left: 18px;
    border-left: 3px solid var(--brand-blue);
    margin-bottom: 40px;
    line-height: 1.5;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-button--ghost {
    background: transparent;
    color: white;
  }

  .cta-button--ghost:hover {
    background: var(--brand-blue);
    color: white;
  }

  @media (max-width: 768px) {
    .hero-content { padding: 40px; }
    .hero h1 { font-size: 56px; }
    .hero h2 { font-size: 26px; }
    .hero .subtitle { font-size: 18px; }
    .hero-buttons { flex-direction: column; align-items: stretch; }
    .cta-button { text-align: center; }
  }
</style>
