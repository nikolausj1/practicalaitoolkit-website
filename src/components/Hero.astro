---
// Hero section: the talk title + subhead + scroll cue.
---
<div class="hero" id="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">Companion site for the Practical AI talk</p>
    <h1>Practical AI</h1>
    <h2>Use AI confidently. Today.</h2>
    <div class="subtitle">
      A plain-language guide to what AI is, when to use it, and how to get great results.
    </div>
    <a class="hero-scroll-cue" href="#what-is-ai" aria-label="Jump to first section">
      <svg class="hero-chevron" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </a>
  </div>
</div>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 120px 40px;
    position: relative;
    background: linear-gradient(135deg, #001f3f 0%, #002a55 60%, #001428 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(0, 102, 204, 0.25) 0%, transparent 45%),
      radial-gradient(circle at 80% 70%, rgba(0, 102, 204, 0.18) 0%, transparent 45%);
    z-index: 0;
  }

  .hero-content {
    width: 100%;
    max-width: 1200px;
    text-align: left;
    background: rgba(0, 31, 63, 0.78);
    backdrop-filter: blur(10px);
    border-left: 5px solid var(--brand-blue);
    padding: 56px 64px;
    position: relative;
    z-index: 1;
    animation: fadeInUp 400ms ease both;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-scroll-cue {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 32px;
    color: rgba(255, 255, 255, 0.55);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .hero-scroll-cue:hover { color: rgba(255, 255, 255, 0.9); }
  .hero-chevron {
    animation: heroBounce 2s ease-in-out infinite;
  }
  @keyframes heroBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-content { animation: none; }
    .hero-chevron { animation: none; }
  }

  .hero-eyebrow {
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-blue);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .hero h1 {
    font-size: 72px;
    font-weight: 700;
    margin: 0 0 14px 0;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero h2 {
    font-size: 32px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 24px 0;
  }

  .hero .subtitle {
    font-size: 20px;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.78);
    padding-left: 18px;
    border-left: 3px solid var(--brand-blue);
    margin-bottom: 0;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .hero { padding: 80px 20px; min-height: 100vh; }
    .hero-content { padding: 36px 28px; }
    .hero h1 { font-size: 48px; }
    .hero h2 { font-size: 24px; }
    .hero .subtitle { font-size: 17px; }
  }
</style>
