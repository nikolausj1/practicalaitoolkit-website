---
interface Props {
  id: string;
  title: string;
  number?: string;
  band: 'light' | 'dark';
}
const { id, title, number, band } = Astro.props;

// Display the digit alone (strip leading zeros) — e.g. "01" → "1", "07" → "7".
const digit = number ? number.replace(/^0+/, '') || '0' : null;
---
<section id={id} class={`scroll-section band-${band}`}>
  {digit && (
    <span class="section-number-bleed" aria-hidden="true">{digit}</span>
  )}
  <div class="section-card">
    <h2 class="section-title">{title}</h2>
    <slot />
  </div>
</section>

<style>
  .scroll-section {
    position: relative;
    overflow: hidden; /* clip the part of the digit that bleeds beyond the section */
  }

  .section-number-bleed {
    position: absolute;
    top: 0;
    /* Bleed off the left edge of the viewport.
       Negative offset shoves the digit out so ~25-30% is clipped. */
    left: -0.22em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    font-weight: 800;
    font-size: clamp(280px, 26vw, 880px);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  /* On light bands (white-ish card on tinted bg), digit is solid dark navy. */
  .scroll-section.band-light .section-number-bleed {
    color: var(--dark-blue);
    opacity: 0.95;
  }

  /* On dark bands (navy gradient), use a tinted blue at low opacity so the
     digit reads as a watermark without competing with the content. */
  .scroll-section.band-dark .section-number-bleed {
    color: rgba(0, 153, 255, 0.16);
  }

  /* Card sits above the digit so its right portion gets hidden by the card on
     narrower viewports — preserves the "bleed in from the left" feel without
     requiring extra horizontal space. */
  .section-card {
    position: relative;
    z-index: 1;
  }

  /* Push the section title down so its baseline sits roughly inline with the
     middle of the giant digit. With the larger digit the card now sits in the
     digit's lower half — when they overlap, the card's white background covers
     the digit (z-index above) so the digit reads as a watermark behind. */
  .section-number-bleed + .section-card {
    padding-top: clamp(48px, 7vw, 140px);
  }

  @media (max-width: 768px) {
    .section-number-bleed {
      left: -0.26em;
    }
    .section-number-bleed + .section-card {
      padding-top: clamp(40px, 9vw, 96px);
    }
  }
</style>
