---
// Email signup band — sits between the last section and the footer.
// Posts to /api/subscribe (Vercel Edge Function) which writes to Upstash Redis.
---
<section class="email-band" aria-labelledby="email-heading">
  <div class="email-band-inner">
    <div class="email-copy">
      <h2 id="email-heading">Stay in the loop</h2>
      <p>
        Hand-picked links when something's worth knowing — a new feature that matters, a model worth
        trying, a prompt that paid off. Unsubscribe anytime.
      </p>
    </div>
    <form class="email-form" id="email-form" novalidate>
      <label class="email-label" for="email-input">Email address</label>
      <div class="email-row">
        <input
          id="email-input"
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          autocomplete="email"
          inputmode="email"
        />
        <button type="submit" id="email-submit">Subscribe</button>
      </div>
      <p class="email-status" id="email-status" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('email-form') as HTMLFormElement | null;
  const input = document.getElementById('email-input') as HTMLInputElement | null;
  const button = document.getElementById('email-submit') as HTMLButtonElement | null;
  const status = document.getElementById('email-status');

  if (form && input && button && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = input.value.trim();
      if (!email) return;

      button.disabled = true;
      status.textContent = '';
      status.className = 'email-status';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data?.error || 'request_failed');
        }
        status.textContent = "You're in. Thanks — I'll be in touch.";
        status.classList.add('email-status--ok');
        form.reset();
      } catch (err) {
        status.textContent =
          err instanceof Error && err.message === 'invalid_email'
            ? "That email doesn't look right — mind double-checking?"
            : "Something glitched on my end. Try again in a moment?";
        status.classList.add('email-status--err');
      } finally {
        button.disabled = false;
      }
    });
  }
</script>

<style>
  .email-band {
    background: linear-gradient(135deg, #001f3f 0%, #002a55 60%, #001428 100%);
    padding: 80px 40px;
    position: relative;
  }
  .email-band::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 30%, rgba(0, 102, 204, 0.22) 0%, transparent 45%),
      radial-gradient(circle at 80% 70%, rgba(0, 102, 204, 0.16) 0%, transparent 45%);
    pointer-events: none;
  }
  .email-band-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .email-copy h2 {
    color: white;
    font-size: 30px;
    line-height: 1.2;
    margin: 0 0 14px 0;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .email-copy p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
  }
  .email-label {
    display: block;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-blue);
    font-weight: 700;
    margin-bottom: 10px;
  }
  .email-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
  }
  .email-row input {
    background: white;
    border: 1px solid rgba(0, 102, 204, 0.35);
    border-radius: 6px;
    padding: 14px 16px;
    font-size: 16px;
    font-family: inherit;
    color: var(--dark-gray);
    width: 100%;
    box-sizing: border-box;
  }
  .email-row input::placeholder { color: var(--med-gray); }
  .email-row input:focus {
    outline: none;
    border-color: var(--brand-blue);
    box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.25);
  }
  .email-row button {
    background: var(--brand-blue);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0 22px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.15s ease, opacity 0.15s ease;
  }
  .email-row button:hover { background: #0077e6; }
  .email-row button:disabled { opacity: 0.55; cursor: wait; }
  .email-status {
    margin: 12px 0 0 0;
    font-size: 13px;
    min-height: 18px;
    color: rgba(255, 255, 255, 0.7);
  }
  .email-status--ok { color: #74e0a8; }
  .email-status--err { color: #ffb3b3; }

  @media (max-width: 800px) {
    .email-band { padding: 56px 20px; }
    .email-band-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .email-copy h2 { font-size: 24px; }
    .email-row { grid-template-columns: 1fr; }
    .email-row button { padding: 14px; }
  }
</style>
