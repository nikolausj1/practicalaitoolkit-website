---
// Generic image lightbox. Auto-binds to <img> elements inside .slide-figure,
// .about-photo, .beyond-figure, or anything with class .lightbox-trigger.
// Closes on overlay click, Escape, or the close button.
---
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
  <button class="lightbox-close" type="button" aria-label="Close">×</button>
  <figure class="lightbox-figure">
    <img class="lightbox-img" id="lightbox-img" alt="" />
    <figcaption class="lightbox-caption" id="lightbox-caption"></figcaption>
  </figure>
</div>

<script>
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lbCap = document.getElementById('lightbox-caption');
  const closeBtn = lightbox?.querySelector<HTMLButtonElement>('.lightbox-close');

  if (lightbox && lbImg && lbCap) {
    const triggers = document.querySelectorAll<HTMLImageElement>(
      '.slide-figure img, .about-photo img, .beyond-figure img, .lightbox-trigger'
    );
    triggers.forEach((trigger) => {
      trigger.style.cursor = 'zoom-in';
      trigger.setAttribute('tabindex', '0');
      trigger.setAttribute('role', 'button');

      const open = () => {
        const src = trigger.currentSrc || trigger.src;
        const alt = trigger.alt || '';
        const fig = trigger.closest('figure');
        const figCap = fig?.querySelector('figcaption');
        lbImg.src = src;
        lbImg.alt = alt;
        lbCap.textContent = figCap?.textContent?.trim() || '';
        lbCap.style.display = lbCap.textContent ? 'block' : 'none';
        lightbox.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
        closeBtn?.focus();
      };

      trigger.addEventListener('click', open);
      trigger.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          open();
        }
      });
    });

    const close = () => {
      lightbox.setAttribute('hidden', '');
      document.body.style.overflow = '';
      lbImg.removeAttribute('src');
    };

    closeBtn?.addEventListener('click', close);
    lightbox.addEventListener('click', (e) => {
      // Close when the overlay is clicked but not when the image itself is tapped.
      if (e.target === lightbox || (e.target as HTMLElement).classList.contains('lightbox-figure')) {
        close();
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox.hasAttribute('hidden')) close();
    });
  }
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 10, 24, 0.94);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px 24px;
    cursor: zoom-out;
    animation: lb-fade 0.18s ease;
  }
  .lightbox[hidden] { display: none; }

  @keyframes lb-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .lightbox-figure {
    margin: 0;
    max-width: 100%;
    max-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .lightbox-img {
    display: block;
    max-width: 100%;
    max-height: calc(100vh - 140px);
    width: auto;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.55);
    cursor: default;
  }

  .lightbox-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    font-size: 26px;
    line-height: 1;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
    z-index: 1;
  }
  .lightbox-close:hover { background: rgba(255, 255, 255, 0.2); transform: scale(1.05); }
  .lightbox-close:focus-visible {
    outline: 2px solid var(--brand-blue);
    outline-offset: 2px;
  }

  .lightbox-caption {
    color: rgba(255, 255, 255, 0.82);
    font-size: 14px;
    margin: 0;
    max-width: 720px;
    text-align: center;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .lightbox { padding: 64px 12px; }
    .lightbox-close { top: 12px; right: 12px; width: 38px; height: 38px; font-size: 22px; }
    .lightbox-img { max-height: calc(100vh - 130px); }
    .lightbox-caption { font-size: 13px; }
  }
</style>
