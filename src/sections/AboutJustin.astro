---
import Section from '../components/Section.astro';

const previousWork = [
  { name: 'Amazon', file: 'amazon.png' },
  { name: 'NASA', file: 'nasa.png' },
  { name: 'Microsoft', file: 'microsoft.png' },
  { name: 'Target', file: 'target.png' },
];
---
<Section id="about" title="About Justin" band="light">
  <div class="about-grid">
    <figure class="about-photo">
      <img
        src="/images/justin-headshot.jpg"
        alt="Justin Nikolaus"
        width="320"
        height="320"
        loading="lazy"
      />
    </figure>
    <div class="about-copy">
      <p class="about-lede">
        A decade of building AI products at Microsoft and Amazon. Now helping organizations put AI to work.
      </p>
      <p>
        I've spent more than ten years at the intersection of AI and design — shaping how people experience
        intelligent technology. At Microsoft, I helped embed intelligent features into Windows. At Amazon,
        I shaped Alexa experiences, including the voice interfaces NASA used for astronauts on lunar missions.
      </p>
      <p>
        Today I work with companies and event audiences on the practical side — what AI is actually good at,
        where it falls down, and how to bring it into the work without the hype or the hand-wringing.
      </p>
      <p>
        <a href="https://practicalaiservices.com" target="_blank" rel="noopener" class="about-link">
          practicalaiservices.com →
        </a>
      </p>
    </div>
  </div>

  <h3 class="prev-work-heading">Previous Work</h3>
  <ul class="prev-work">
    {previousWork.map((co) => (
      <li>
        <img
          src={`/images/logos/${co.file}`}
          alt={co.name}
          loading="lazy"
        />
      </li>
    ))}
  </ul>
</Section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 48px;
    align-items: start;
    margin: 30px 0 0 0;
  }
  .about-photo {
    margin: 0;
  }
  .about-photo img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    display: block;
    box-shadow: 0 8px 28px rgba(0, 31, 63, 0.18);
  }
  .about-copy p {
    color: var(--dark-gray);
    font-size: 17px;
    line-height: 1.7;
    margin: 0 0 18px 0;
  }
  .about-copy .about-lede {
    font-size: 22px;
    font-weight: 500;
    color: var(--dark-gray);
    line-height: 1.4;
    margin-bottom: 22px;
  }
  .about-link {
    color: var(--brand-blue);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 102, 204, 0.35);
    font-weight: 600;
  }
  .about-link:hover {
    color: #004999;
    border-bottom-color: var(--brand-blue);
  }

  .prev-work-heading {
    margin-top: 60px !important;
    color: var(--dark-gray);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .prev-work {
    list-style: none;
    margin: 24px 0 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 56px;
  }
  .prev-work li {
    display: flex;
    align-items: center;
    height: 40px;
  }
  .prev-work img {
    height: 36px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.7;
    transition: opacity 0.2s ease, filter 0.2s ease;
  }
  .prev-work img:hover {
    opacity: 1;
    filter: grayscale(0%);
  }

  @media (max-width: 720px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .about-photo {
      max-width: 220px;
    }
    .about-copy .about-lede { font-size: 19px; }
    .prev-work {
      gap: 36px;
    }
    .prev-work img { height: 28px; }
  }
</style>
