---
import Section from '../components/Section.astro';

const aiTypes = [
  {
    title: 'Predictive AI',
    body: 'Predicts outcomes from patterns in data. Powers fraud detection, recommendation engines, demand forecasting, medical diagnostics. It tells you what is likely to happen.',
  },
  {
    title: 'Generative AI',
    body: 'Creates new content — text, images, code, audio, video. Powers ChatGPT, Claude, Midjourney, and the tools this site is mostly about. It produces something that did not exist a moment ago.',
  },
];

const modes = [
  {
    title: 'Fast Mode',
    body: 'Instant answers. Great for everyday questions, quick rewrites, brainstorming, and routine tasks. Pick this 90% of the time.',
  },
  {
    title: 'Thinking Mode',
    body: 'The model deliberates before answering. Slower, but much better at complex reasoning, multi-step problems, math, and code. Reach for it when the stakes are higher.',
  },
];

const features = [
  {
    name: 'Thinking Mode',
    definition:
      'A setting that tells the model to deliberate step-by-step before answering instead of responding instantly. Trades speed for accuracy on hard problems.',
    example:
      'Ask Claude to plan a five-day Tokyo trip with three kids, dietary restrictions, and a $3,000 cap. Fast Mode gives you a generic itinerary; Thinking Mode actually reconciles the constraints and flags conflicts.',
    examples_label: 'Available in',
    links: [
      { label: 'Claude (Extended Thinking)', href: 'https://docs.anthropic.com/en/docs/build-with-claude/extended-thinking' },
      { label: 'ChatGPT (o-series)', href: 'https://openai.com/index/learning-to-reason-with-llms/' },
      { label: 'Gemini (Deep Think)', href: 'https://blog.google/products/gemini/gemini-2-5-deep-think/' },
      { label: 'Grok (Think)', href: 'https://x.ai/news/grok-3' },
    ],
  },
  {
    name: 'Web Search',
    definition:
      'Lets the AI look things up live on the open web instead of relying only on its training data. The model decides when to search; you can usually force it on or off.',
    example:
      'Ask "what changed in the SEC\'s climate disclosure rule this month?" Without web search the model is stuck at its training cutoff and may guess. With it, you get a current answer with links.',
    examples_label: 'Available in',
    prefix: 'Every major chat tool — ',
    links: [
      { label: 'ChatGPT', href: 'https://help.openai.com/en/articles/9237897-chatgpt-search' },
      { label: 'Claude', href: 'https://www.anthropic.com/news/web-search' },
      { label: 'Gemini', href: 'https://gemini.google/' },
      { label: 'Copilot', href: 'https://copilot.microsoft.com/' },
      { label: 'Grok', href: 'https://x.ai/' },
      { label: 'Perplexity (built around it)', href: 'https://www.perplexity.ai/' },
    ],
  },
  {
    name: 'Deep Research',
    definition:
      'An autonomous research mode where the AI plans a multi-step investigation, browses dozens of sources, and produces a cited written report. Takes 5–30 minutes; runs while you do other things.',
    example:
      '"Build me a competitive landscape of US-based vertical SaaS companies with under 50 employees serving the construction industry. Include funding, headcount, and a one-line take on each." You get a footnoted report you can hand to a stakeholder.',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT (Deep Research)', href: 'https://openai.com/index/introducing-deep-research/' },
      { label: 'Gemini (Deep Research)', href: 'https://blog.google/products/gemini/google-gemini-deep-research/' },
      { label: 'Perplexity (Deep Research)', href: 'https://www.perplexity.ai/hub/blog/introducing-perplexity-deep-research' },
      { label: 'Grok (DeepSearch)', href: 'https://x.ai/news/grok-3' },
    ],
  },
  {
    name: 'Memory',
    definition:
      'The model remembers things you tell it across separate conversations — your name, role, preferences, ongoing projects — without you having to repeat yourself every time. You can review and edit what it remembers.',
    example:
      'Tell ChatGPT once that you write in plain language, prefer bullet lists, and work in higher ed. From then on, every new chat opens with that context already loaded — no preamble required.',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT (Memory)', href: 'https://openai.com/index/memory-and-new-controls-for-chatgpt/' },
      { label: 'Claude (Project memory)', href: 'https://www.anthropic.com/news/projects' },
      { label: 'Gemini (Memory)', href: 'https://blog.google/products/gemini/google-gemini-personalization/' },
      { label: 'Grok', href: 'https://x.ai/' },
    ],
  },
  {
    name: 'Personalization',
    definition:
      'Set persistent instructions that shape how the AI talks to you — tone, length, default formatting, what to assume about your work — applied to every new conversation.',
    example:
      'Tell Claude once: "I\'m a marketing director. Default to 200-word responses, skip the disclaimers, and challenge weak ideas instead of just agreeing." Every chat starts in that mode.',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT (Custom Instructions)', href: 'https://openai.com/index/custom-instructions-for-chatgpt/' },
      { label: 'Claude (System Prompts / Styles)', href: 'https://www.anthropic.com/news/styles' },
      { label: 'Gemini (Saved Info)', href: 'https://support.google.com/gemini/answer/15637730' },
    ],
  },
  {
    name: 'Document Analysis',
    definition:
      'Drop a PDF, Word doc, spreadsheet, slide deck, or audio file into the chat. The model reads it as part of your conversation and can summarize, compare, redline, pull data, or answer questions about it.',
    example:
      'Upload a 60-page contract and ask: "summarize the obligations on us, list anything unusual compared to a standard MSA, and draft a redline I can send back."',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT', href: 'https://chatgpt.com/' },
      { label: 'Claude', href: 'https://claude.ai/' },
      { label: 'Gemini', href: 'https://gemini.google.com/' },
      { label: 'Copilot', href: 'https://copilot.microsoft.com/' },
      { label: 'Grok', href: 'https://grok.com/' },
    ],
  },
  {
    name: 'Image Analysis',
    definition:
      'Upload a photo, screenshot, chart, or whiteboard scribble and the model can read what\'s in it — text, diagrams, objects, handwriting — and answer questions about it.',
    example:
      'Photograph a confusing nutrition label and ask "is this OK for someone on a low-FODMAP diet, and what are the worst ingredients?" Or paste a screenshot of an error message and ask what\'s wrong and how to fix it.',
    examples_label: 'Available in',
    prefix: 'Every major chat tool now sees images — ',
    links: [
      { label: 'ChatGPT', href: 'https://chatgpt.com/' },
      { label: 'Claude', href: 'https://claude.ai/' },
      { label: 'Gemini', href: 'https://gemini.google.com/' },
      { label: 'Copilot', href: 'https://copilot.microsoft.com/' },
      { label: 'Grok', href: 'https://grok.com/' },
    ],
  },
  {
    name: 'Image Generation',
    definition:
      'Create images from a text description. Modern versions also edit images you provide — change the background, swap the outfit, restyle, remove a person, or extend the canvas.',
    example:
      'Upload a phone photo of your living room and prompt "make it look like a Pacific Northwest cabin — wood walls, warm light, fewer cables." You get a preview good enough to share with a designer.',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT (GPT-Image)', href: 'https://openai.com/index/introducing-4o-image-generation/' },
      { label: 'Gemini (Imagen / Nano Banana)', href: 'https://blog.google/products/gemini/updated-image-editing-model/' },
      { label: 'Midjourney', href: 'https://www.midjourney.com/' },
      { label: 'Flux', href: 'https://blackforestlabs.ai/' },
      { label: 'Adobe Firefly', href: 'https://firefly.adobe.com/' },
    ],
  },
  {
    name: 'Voice Mode',
    definition:
      'Talk to the model and have it talk back, in real time, with a natural-sounding voice. Most implementations now hear tone of voice and can be interrupted mid-sentence.',
    example:
      'Run a 20-minute mock interview while you walk the dog. The model plays a tough hiring manager, asks follow-ups, then debriefs you on what to tighten. No typing.',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT (Advanced Voice)', href: 'https://help.openai.com/en/articles/8400625-voice-mode-faq' },
      { label: 'Gemini Live', href: 'https://gemini.google/overview/gemini-live/' },
      { label: 'Claude (voice on mobile)', href: 'https://www.anthropic.com/news/claude-voice-mode' },
      { label: 'Grok (Voice Mode)', href: 'https://x.ai/' },
    ],
  },
  {
    name: 'Video Mode',
    definition:
      'Two flavors. (1) The model can see your camera or screen in real time and react to what\'s in front of it. (2) The model can generate full video clips from a text prompt.',
    example:
      'Point your phone at a broken sprinkler valve and ask "what is this part and where do I get a replacement?" — the model identifies it on camera. Or generate a 10-second cinematic shot of a kayak gliding through fog with Veo or Sora.',
    examples_label: 'Available in',
    groups: [
      {
        label: 'Live video',
        links: [
          { label: 'ChatGPT', href: 'https://help.openai.com/en/articles/10119604-video-and-screensharing-on-chatgpt' },
          { label: 'Gemini Live', href: 'https://gemini.google/overview/gemini-live/' },
        ],
      },
      {
        label: 'Generation',
        links: [
          { label: 'Sora (OpenAI)', href: 'https://sora.com/' },
          { label: 'Veo (Google)', href: 'https://deepmind.google/models/veo/' },
          { label: 'Runway', href: 'https://runwayml.com/' },
          { label: 'Kling', href: 'https://www.klingai.com/' },
        ],
      },
    ],
  },
  {
    name: 'Coding',
    definition:
      'The model can write code in any common language, explain it, debug it, and in many tools actually run it in a sandbox to verify the result. Goes well beyond pasting a snippet.',
    example:
      'Upload a messy CSV of sales data and ask "what were the top 5 products by margin in Q3, and chart them by week?" The model writes Python, runs it, and returns the numbers + a chart — no spreadsheet acrobatics.',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT (Code Interpreter)', href: 'https://help.openai.com/en/articles/8077698-how-do-i-use-the-code-interpreter-tool' },
      { label: 'Claude (Analysis Tool, Claude Code)', href: 'https://www.anthropic.com/claude-code' },
      { label: 'Gemini', href: 'https://gemini.google.com/' },
      { label: 'Cursor', href: 'https://cursor.com/' },
      { label: 'Windsurf', href: 'https://windsurf.com/' },
      { label: 'GitHub Copilot', href: 'https://github.com/features/copilot' },
    ],
  },
  {
    name: 'Computer Use',
    definition:
      'Give the model control of a virtual desktop — it can move the mouse, click, type, open apps, and operate software the same way you would. The lower-level cousin of Agent Mode.',
    example:
      'Hand Claude a spreadsheet, ask it to open a browser-based BI tool, build a specific report, and save the result back to your folder. It drives the apps directly instead of telling you what to click.',
    examples_label: 'Available in',
    links: [
      { label: 'Claude (Computer Use)', href: 'https://www.anthropic.com/news/3-5-models-and-computer-use' },
      { label: 'ChatGPT (Operator)', href: 'https://openai.com/index/introducing-operator/' },
      { label: 'Gemini (Project Mariner)', href: 'https://deepmind.google/models/project-mariner/' },
    ],
  },
  {
    name: 'Agent Mode',
    definition:
      'The AI doesn\'t just write the answer — it does the work. It plans the steps, opens a browser, fills forms, runs code, and returns a finished result. You set the goal; it figures out the path.',
    example:
      '"Find me three flights from SEA to BOS next Friday under $400, in a comparison table, then add the best one to my calendar." The agent opens kayak.com, runs the searches, and (with permission) writes the calendar event.',
    examples_label: 'Available in',
    links: [
      { label: 'ChatGPT (Agent Mode)', href: 'https://openai.com/index/introducing-chatgpt-agent/' },
      { label: 'Claude (Claude Code, Computer Use)', href: 'https://www.anthropic.com/claude-code' },
      { label: 'Gemini (Project Mariner)', href: 'https://deepmind.google/models/project-mariner/' },
    ],
  },
  {
    name: 'Connectors & MCP',
    definition:
      'Plug the AI directly into your tools — Gmail, Drive, Notion, Slack, GitHub, your database — so it can read and act in those systems with your permission. MCP (Model Context Protocol) is the open standard that powers most of this.',
    example:
      'Connect Claude to your Notion workspace and Google Calendar, then ask: "look at my project plan in Notion, find this week\'s deadlines, and tell me which meetings on my calendar should be moved." It reads both directly — no copy-paste.',
    examples_label: 'Available in',
    links: [
      { label: 'Claude (Connectors / MCP)', href: 'https://www.anthropic.com/news/integrations' },
      { label: 'ChatGPT (Connectors)', href: 'https://help.openai.com/en/articles/11487775-connectors-in-chatgpt' },
      { label: 'Gemini (Workspace integrations)', href: 'https://workspace.google.com/solutions/ai/' },
      { label: 'MCP spec', href: 'https://modelcontextprotocol.io/' },
    ],
  },
  {
    name: 'Skills',
    definition:
      'Reusable instruction packs you install once and then invoke by name — like add-ons that teach the model a specific workflow, format, or set of guardrails.',
    example:
      'Install a "Brand Voice" skill that knows your style guide, tone, and forbidden words. From then on you can say "draft this announcement using brand-voice" and it produces on-brand copy without re-explaining the rules each time.',
    examples_label: 'Available in',
    links: [
      { label: 'Claude (Skills)', href: 'https://www.anthropic.com/news/skills' },
      { label: 'ChatGPT (GPTs play a similar role)', href: 'https://openai.com/index/introducing-gpts/' },
    ],
  },
  {
    name: 'Projects',
    definition:
      'A persistent workspace that bundles a set of files, custom instructions, and chat history around a single piece of work. Every conversation inside the project shares that context.',
    example:
      'Create a "Q4 Board Deck" project, drop in last quarter\'s deck, the financial model, and a rubric for what good slides look like. Any chat in that project already knows your goals, history, and constraints.',
    examples_label: 'Available in',
    links: [
      { label: 'Claude (Projects)', href: 'https://www.anthropic.com/news/projects' },
      { label: 'ChatGPT (Projects)', href: 'https://help.openai.com/en/articles/10169521-using-projects-in-chatgpt' },
      { label: 'Gemini (Gems)', href: 'https://gemini.google/overview/gems/' },
      { label: 'Notion AI', href: 'https://www.notion.com/product/ai' },
    ],
  },
];
---
<Section id="what-is-ai" number="01" title="What is AI?" band="light">
  <p>
    AI is a technology that learns patterns from massive amounts of data and uses those patterns to do new things —
    answer questions, generate writing, summarize documents, write code, create images, and a lot more.
  </p>

  <h3>Two Main Types of AI</h3>
  <div class="card-grid">
    {aiTypes.map((t) => (
      <div class="card">
        <h4>{t.title}</h4>
        <p>{t.body}</p>
      </div>
    ))}
  </div>

  <h3>How These Models Learn</h3>
  <p>
    Modern AI models are trained on billions of examples — books, articles, websites, and conversations. They
    learn patterns: grammar, facts, reasoning, code structure, what good writing sounds like. Once trained, they
    don't look anything up. They predict, token by token, what should come next given everything they've seen.
  </p>

  <h3>The AI Tool Landscape</h3>
  <figure class="slide-figure">
    <picture>
      <source srcset="/images/tools.webp" type="image/webp" />
      <img
        src="/images/tools.jpg"
        alt="The AI tool landscape — General Tools (ChatGPT, Gemini, Claude, Grok, Meta AI, Mistral AI) and Specialized Tools (Perplexity, Grammarly, Gamma, Midjourney, Fireflies, Jasper, ElevenLabs, Copilot)."
        width="1800"
        height="688"
        loading="lazy"
      />
    </picture>
  </figure>

  <h3>Different Modes</h3>
  <div class="card-grid" style="grid-template-columns: 1fr 1fr;">
    {modes.map((m) => (
      <div class="card">
        <h4>{m.title}</h4>
        <p>{m.body}</p>
      </div>
    ))}
  </div>

  <h3>Tools &amp; Features</h3>
  <figure class="slide-figure">
    <picture>
      <source srcset="/images/features.webp" type="image/webp" />
      <img
        src="/images/features.jpg"
        alt="AI tools and features overview — floating labels for Agent Mode, Deep Research, Memory, Video Mode, Thinking Mode, Voice Mode, Connectors & MCP, Personalization, Skills, Computer Use, Web Search, Coding, Document Analysis, Image Generation, Image Analysis, and Projects."
        loading="lazy"
        width="1800"
        height="874"
      />
    </picture>
  </figure>
  <p style="margin-top: 30px;">Today's AI assistants are no longer just text-in / text-out. These are the features that matter most — what each one is, when to reach for it, and where to find it.</p>

  <div class="feature-list">
    {features.map((f, idx) => (
      <article class="feature-row">
        <div class="feature-num">{String(idx + 1).padStart(2, '0')}</div>
        <div class="feature-body">
          <h4>{f.name}</h4>
          <p class="feature-def">{f.definition}</p>
          <p class="feature-example"><strong>Example:</strong> {f.example}</p>
          <p class="feature-where">
            <strong>{f.examples_label}:</strong>{' '}
            {f.groups ? (
              f.groups.map((g, gi) => (
                <>
                  {gi > 0 && <span class="group-sep"> · </span>}
                  <span class="group-label">{g.label}:</span>{' '}
                  {g.links.map((l, li) => (
                    <>
                      {li > 0 && <span class="link-sep"> · </span>}
                      <a href={l.href} target="_blank" rel="noopener noreferrer" class="feature-link">{l.label}</a>
                    </>
                  ))}
                </>
              ))
            ) : (
              <>
                {f.prefix}
                {f.links.map((l, li) => (
                  <>
                    {li > 0 && <span class="link-sep"> · </span>}
                    <a href={l.href} target="_blank" rel="noopener noreferrer" class="feature-link">{l.label}</a>
                  </>
                ))}
              </>
            )}
          </p>
        </div>
      </article>
    ))}
  </div>
</Section>

<style>
  .tool-list { list-style: none; margin: 30px 0; padding: 0; }
  .tool-list li {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 18px;
    color: var(--dark-gray);
  }
  .tool-logo {
    width: 22px;
    height: 22px;
    flex: 0 0 22px;
    object-fit: contain;
  }
  .tool-logo--fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--brand-blue);
    color: white;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 700;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 30px 0 0 0;
    border-top: 1px solid rgba(0, 102, 204, 0.18);
  }
  .feature-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(0, 102, 204, 0.18);
    align-items: start;
  }
  .feature-num {
    color: var(--brand-blue);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.18em;
    padding-top: 4px;
  }
  .feature-body h4 {
    font-size: 24px;
    font-weight: 700;
    color: var(--dark-gray);
    margin: 0 0 10px 0;
  }
  .feature-def {
    color: var(--dark-gray);
    font-size: 17px;
    line-height: 1.7;
    margin: 0 0 14px 0;
  }
  .feature-example {
    color: var(--dark-gray);
    font-size: 16px;
    line-height: 1.7;
    margin: 0 0 12px 0;
    padding: 14px 18px;
    background: rgba(0, 102, 204, 0.06);
    border-left: 3px solid var(--brand-blue);
    border-radius: 4px;
  }
  .feature-where {
    color: var(--med-gray);
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }
  .feature-link {
    color: var(--brand-blue);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 102, 204, 0.3);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .feature-link:hover {
    color: #004999;
    border-bottom-color: var(--brand-blue);
  }
  .feature-link:focus-visible {
    outline: 2px solid var(--brand-blue);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .group-label {
    color: var(--dark-gray);
    font-weight: 600;
  }
  .link-sep,
  .group-sep {
    color: var(--med-gray);
  }
  .feature-where strong {
    color: var(--brand-blue);
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .feature-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .feature-body h4 { font-size: 20px; }
    .feature-def { font-size: 16px; }
  }
</style>
