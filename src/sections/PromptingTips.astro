---
import Section from '../components/Section.astro';

const tips = [
  {
    title: 'Ask Me Questions',
    why: 'Stop guessing what info the AI needs. Let it interview you.',
    prompt: "Before you answer, ask me one question at a time until you have enough context to give me a great response. Then answer.",
  },
  {
    title: 'Help Me Create a Prompt',
    why: 'Use AI to write better prompts for AI.',
    prompt: "I want to create [a meeting agenda for my team's quarterly review]. Help me create a prompt that will produce a great result. Ask me clarifying questions first if you need them.",
  },
  {
    title: 'Match My Tone',
    why: 'AI defaults to a generic voice. Anchor it to yours.',
    prompt: "Here's a sample of how I write. Match this tone and style in the response below:\n\n[paste 1–2 paragraphs of your writing]\n\nNow respond to: [your actual ask]",
  },
  {
    title: 'Favorite Commands',
    why: 'A few one-liners that punch way above their weight.',
    prompt: 'Rewrite this paragraph using a friendly tone of voice.\nElaborate on the third bullet.\nMake it half as long without losing the substance.\nWhat\'s the strongest objection to this argument?\nTranslate this for a non-technical audience.',
  },
  {
    title: 'Upload Files',
    why: 'Most modern AI tools accept PDFs, docs, spreadsheets, and images. Use them.',
    prompt: 'Upload a long PDF and ask: "Summarize the key arguments in 5 bullets, then list the 3 weakest claims and why."',
  },
  {
    title: "Show, Don't Just Tell",
    why: 'One concrete example beats five sentences of instructions.',
    prompt: "Here's an example of the kind of output I want:\n\n[paste a great example]\n\nNow produce something similar for: [your input]",
  },
];
---
<Section id="prompting-tips" number="04" title="Prompting Tips" band="dark">
  <p>
    Beyond RTCF, a small set of techniques will make almost every prompt better. Each tip below comes
    with a copy-pasteable starter you can drop into any AI tool today.
  </p>

  <div class="tips-list">
    {tips.map((t, idx) => (
      <article class="tip-row">
        <div class="tip-num">{String(idx + 1).padStart(2, '0')}</div>
        <div class="tip-body">
          <h3>{t.title}</h3>
          <p class="tip-why">{t.why}</p>
          <div class="prompt-card">
            <button
              type="button"
              class="copy-btn"
              data-prompt={t.prompt}
              aria-label={`Copy prompt: ${t.title}`}
            >
              <svg class="copy-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span class="copy-label">Copy</span>
            </button>
            <pre class="prompt-text">{t.prompt}</pre>
          </div>
        </div>
      </article>
    ))}
  </div>
</Section>

<script is:inline>
  document.querySelectorAll('.copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var text = btn.getAttribute('data-prompt') || '';
      // Replace literal \n escape sequences with real newlines (defensive — data-* may have been HTML-escaped)
      text = text.replace(/\\n/g, '\n');
      var done = function () {
        btn.classList.add('copied');
        var label = btn.querySelector('.copy-label');
        if (label) label.textContent = 'Copied';
        setTimeout(function () {
          btn.classList.remove('copied');
          if (label) label.textContent = 'Copy';
        }, 1800);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done).catch(function () {
          // Fallback
          var ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); done(); } catch (e) {}
          document.body.removeChild(ta);
        });
      }
    });
  });
</script>

<style>
  .tips-list {
    display: flex;
    flex-direction: column;
    gap: 36px;
    margin-top: 30px;
  }
  .tip-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    align-items: start;
  }
  .tip-num {
    color: var(--brand-blue);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.18em;
    padding-top: 6px;
  }
  .tip-body h3 {
    color: white;
    margin: 0 0 8px 0;
    font-size: 26px;
    font-weight: 700;
  }
  .tip-why {
    font-style: italic;
    color: rgba(255, 255, 255, 0.78);
    margin: 0 0 16px 0;
    font-size: 17px;
  }

  .prompt-card {
    position: relative;
    background: white;
    color: var(--dark-gray);
    border-radius: 8px;
    border: 1px solid rgba(0, 102, 204, 0.25);
    padding: 22px 24px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
  }
  .prompt-text {
    margin: 0;
    padding: 0;
    padding-right: 90px;
    font-family: 'SF Mono', Menlo, Consolas, 'Courier New', monospace;
    font-size: 15px;
    line-height: 1.7;
    color: var(--dark-gray);
    white-space: pre-wrap;
    word-wrap: break-word;
    background: transparent;
  }
  @media (max-width: 768px) {
    .prompt-text { padding-right: 0; padding-top: 44px; }
  }

  .copy-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    background: rgba(0, 102, 204, 0.08);
    color: var(--brand-blue);
    border: 1px solid rgba(0, 102, 204, 0.3);
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .copy-btn:hover {
    background: var(--brand-blue);
    color: white;
    border-color: var(--brand-blue);
  }
  .copy-btn .check-icon { display: none; }
  .copy-btn.copied .copy-icon { display: none; }
  .copy-btn.copied .check-icon { display: inline-block; }
  .copy-btn.copied {
    background: #1a8754;
    border-color: #1a8754;
    color: white;
  }

  @media (max-width: 768px) {
    .tip-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .tip-body h3 { font-size: 22px; }
  }
</style>
